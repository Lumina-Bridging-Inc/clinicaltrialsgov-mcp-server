# -----------------------------------------------------------------
# MCP Server Configuration
# -----------------------------------------------------------------

# Transport type: "stdio" or "http"
MCP_TRANSPORT_TYPE=http

# Session mode: "stateless", "stateful", or "auto"
MCP_SESSION_MODE=stateless

# Log level: "debug", "info", "warning", "error", "crit", "alert", "emerg"
MCP_LOG_LEVEL=info

# Force logs to stdout (required for Railway / container environments)
MCP_FORCE_CONSOLE_LOGGING=true

# Node environment
NODE_ENV=production

# -----------------------------------------------------------------
# HTTP Transport Configuration (only used if MCP_TRANSPORT_TYPE=http)
# -----------------------------------------------------------------

# Bind to all interfaces (required for Railway)
# Railway injects PORT automatically; do not set MCP_HTTP_PORT here
MCP_HTTP_HOST=0.0.0.0

# -----------------------------------------------------------------
# Authentication Configuration (optional)
# -----------------------------------------------------------------

# Auth mode: "none", "jwt", or "oauth"
# MCP_AUTH_MODE=none

# JWT mode: set a secret key (must be at least 32 characters)
# MCP_AUTH_SECRET_KEY=

# -----------------------------------------------------------------
# OAuth / Zitadel Configuration (only used if MCP_AUTH_MODE=oauth)
# -----------------------------------------------------------------
# OAUTH_ISSUER_URL=https://your-instance.zitadel.cloud
# OAUTH_AUDIENCE=<your-zitadel-project-id>
# OAUTH_JWKS_URI=https://your-instance.zitadel.cloud/oauth/v2/keys
# OAUTH_JWKS_COOLDOWN_MS=300000
# OAUTH_JWKS_TIMEOUT_MS=5000
#
# Zitadel claim mapping (handled automatically):
#   client_id: extracted from azp, client_id, or cid claims
#   tenant_id: extracted from tid or urn:zitadel:iam:user:resourceowner:id claims
#   scopes:    extracted from scope or scp claims
#
# Zitadel setup notes:
#   1. Create a Service User with JWT access token type
#   2. Use client_credentials grant or private_key_jwt
#   3. Request scope: urn:zitadel:iam:org:project:id:<projectId>:aud
#   4. Request scope: urn:zitadel:iam:user:resourceowner (for tenant/org ID)
#   5. Zitadel does NOT support RFC 8707 — do not set MCP_SERVER_RESOURCE_IDENTIFIER

# -----------------------------------------------------------------
# Database / Storage Configuration (optional)
# -----------------------------------------------------------------

# Default storage is in-memory. Uncomment to use Supabase instead.
# STORAGE_PROVIDER_TYPE=supabase
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
