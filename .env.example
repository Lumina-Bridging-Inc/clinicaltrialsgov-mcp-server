# -----------------------------------------------------------------
# MCP Server Configuration
# -----------------------------------------------------------------

# Transport type: "stdio" or "http"
MCP_TRANSPORT_TYPE=http

# Session mode: "stateless", "stateful", or "auto"
MCP_SESSION_MODE=stateless

# Log level: "debug", "info", "warning", "error", "crit", "alert", "emerg"
MCP_LOG_LEVEL=info

# Force logs to stdout (required for Railway / container environments)
MCP_FORCE_CONSOLE_LOGGING=true

# Node environment
NODE_ENV=production

# -----------------------------------------------------------------
# HTTP Transport Configuration (only used if MCP_TRANSPORT_TYPE=http)
# -----------------------------------------------------------------

# Bind to all interfaces (required for Railway)
# Railway injects PORT automatically; do not set MCP_HTTP_PORT here
MCP_HTTP_HOST=0.0.0.0

# -----------------------------------------------------------------
# Authentication Configuration (optional)
# -----------------------------------------------------------------

# Uncomment and set a real secret to enable JWT authentication.
# Must be at least 32 characters. Leave unset to disable auth.
# MCP_AUTH_SECRET_KEY=

# -----------------------------------------------------------------
# Database / Storage Configuration (optional)
# -----------------------------------------------------------------

# Default storage is in-memory. Uncomment to use Supabase instead.
# STORAGE_PROVIDER_TYPE=supabase
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
